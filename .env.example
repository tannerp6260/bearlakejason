# Static form endpoint used by ContactForm.
# Examples: a Formspree endpoint, Basin endpoint, or a Cloudflare Pages Function route such as /api/contact.
PUBLIC_FORM_ENDPOINT=https://formspree.io/f/xlgzojyv

# Google Ads website conversion tracking.
# Find these after creating a Google Ads website conversion action with manual/code setup.
# Conversion ID format usually starts with AW-, for example AW-123456789.
PUBLIC_GOOGLE_ADS_CONVERSION_ID=
PUBLIC_GOOGLE_ADS_CONTACT_CONVERSION_LABEL=
