---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/forms/ContactForm.astro';
import CTASection from '@/components/sections/CTASection.astro';
---
<BaseLayout title="Buying & Selling Bear Lake Real Estate" description="Buyer and seller guidance for Bear Lake cabins, second homes, building lots, CMAs, valuation, and local Utah and Idaho considerations.">
  <section class="py-16 sm:py-24"><div class="container-narrow"><p class="eyebrow">Buying & Selling</p><h1 class="mt-4 font-serif text-5xl font-semibold tracking-tight">Buying and Selling Bear Lake Real Estate with Local Context</h1><p class="mt-6 text-lg leading-8 text-lake-900/75">Jason helps Bear Lake buyers and sellers move beyond generic online data with local insight, current market conversations, and a practical plan for homes, cabins, lots, land, condos, townhomes, and second homes.</p></div></section>
  <section class="bg-white py-16"><div class="container-wide grid gap-8 lg:grid-cols-2"><article class="card"><h2 class="font-serif text-3xl font-semibold">For Buyers</h2><ul class="mt-6 grid gap-4 leading-7 text-lake-900/75"><li>Compare Bear Lake homes, cabins, condos, townhomes, second homes, lots, and neighborhoods by lifestyle and ownership goals.</li><li>Evaluate Bear Lake building lots, utilities, access, slope, construction cost considerations, and builder fit.</li><li>Understand Utah versus Idaho considerations around location, rules, travel patterns, and property type.</li><li>Discuss nightly rental possibilities, rentable versus non-rentable areas, HOA rules, and short-term rental considerations without presenting rental income or investment returns as guaranteed.</li><li>Negotiate with context because the list price is not always the final price.</li><li>Receive local insights about HOA information, neighborhood differences, amenities, property features, and recent Bear Lake sales that broad online searches may not show.</li></ul></article><article class="card"><h2 class="font-serif text-3xl font-semibold">For Sellers</h2><ul class="mt-6 grid gap-4 leading-7 text-lake-900/75"><li>Request a CMA / property valuation conversation grounded in current competition and actual sold data.</li><li>Review what is currently listed and what has actually sold around your property type.</li><li>Build a pricing strategy that fits timing, condition, location, and buyer demand.</li><li>Discuss practical home improvement, landscaping, and curb appeal suggestions that may help the property show well without overspending.</li><li>Plan marketing that can include professional photography, drone footage, a complete photo package, printed brochures at local Bear Lake businesses, and direct communication about commission questions.</li></ul></article></div></section>
  <section class="py-16"><div class="container-narrow"><h2 class="font-serif text-3xl font-semibold">Quick Seller Valuation Form</h2><p class="mt-4 leading-7 text-lake-900/70">Share the basics and Jason can follow up about your Bear Lake property.</p><div class="mt-8"><ContactForm type="seller" /></div></div></section>
  <CTASection />
</BaseLayout>
