---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/forms/ContactForm.astro';
import CTASection from '@/components/sections/CTASection.astro';
---
<BaseLayout title="Buying & Selling Bear Lake Real Estate" description="Buyer and seller guidance for Bear Lake cabins, second homes, building lots, CMAs, valuation, and local Utah and Idaho considerations.">
  <section class="py-16 sm:py-24"><div class="container-narrow"><p class="eyebrow">Buying & selling</p><h1 class="mt-4 font-serif text-5xl font-semibold tracking-tight">Buying and selling Bear Lake real estate with local context</h1><p class="mt-6 text-lg leading-8 text-lake-900/75">Jason helps Bear Lake buyers and sellers move beyond generic online data with local insight, current market conversations, and a practical plan.</p></div></section>
  <section class="bg-white py-16"><div class="container-wide grid gap-8 lg:grid-cols-2"><article class="card"><h2 class="font-serif text-3xl font-semibold">For buyers</h2><ul class="mt-6 grid gap-4 leading-7 text-lake-900/75"><li>Compare Bear Lake second homes, cabins, and neighborhoods by lifestyle and ownership goals.</li><li>Evaluate Bear Lake building lots, utilities, access, slope, construction cost considerations, and builder fit.</li><li>Understand Utah versus Idaho side considerations around location, rules, travel patterns, and property type.</li><li>Discuss rentable versus non-rentable areas and vacation-rental considerations without assuming guaranteed income.</li><li>Negotiate with context instead of assuming the list price is the final price.</li><li>Get local insights beyond Zillow and broad online searches.</li></ul></article><article class="card"><h2 class="font-serif text-3xl font-semibold">For sellers</h2><ul class="mt-6 grid gap-4 leading-7 text-lake-900/75"><li>Request a CMA / property valuation conversation grounded in current competition and actual sold data.</li><li>Review what is currently listed and what has actually sold around your property type.</li><li>Build a pricing strategy that fits timing, condition, location, and buyer demand.</li><li>Discuss upgrade recommendations that may improve ROI without overspending.</li><li>Handle commission questions directly and conversationally.</li></ul></article></div></section>
  <section class="py-16"><div class="container-narrow"><h2 class="font-serif text-3xl font-semibold">Short seller valuation form</h2><p class="mt-4 leading-7 text-lake-900/70">Share the basics and Jason can follow up about your Bear Lake property.</p><div class="mt-8"><ContactForm type="seller" /></div></div></section>
  <CTASection />
</BaseLayout>
