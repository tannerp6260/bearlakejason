---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/sections/CTASection.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import { site } from '@/data/site';
import { towns } from '@/data/towns';
import { withBasePath } from '@/utils/paths';

const communitySchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${site.domain}/bear-lake-communities/#webpage`,
    url: `${site.domain}/bear-lake-communities/`,
    name: 'Bear Lake Communities in Utah and Idaho',
    description:
      'A practical guide to comparing Bear Lake communities such as Garden City, Laketown, Fish Haven, and St. Charles for buyers and sellers.',
    isPartOf: { '@id': `${site.domain}/#website` },
    about: { '@id': `${site.domain}/#real-estate-agent` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: `${site.domain}/`,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Bear Lake Communities',
        item: `${site.domain}/bear-lake-communities/`,
      },
    ],
  },
];

const comparisonPoints = [
  'Utah versus Idaho location and licensing considerations',
  'Winter access, drive time, and year-round usability',
  'HOA rules, architectural standards, and rental restrictions',
  'Utilities, water, septic, slope, and buildability for land',
  'Lake access, marinas, views, recreation, and neighborhood feel',
  'Current inventory, recent comparable sales, and seasonal demand',
];
---
<BaseLayout title="Bear Lake Communities in Utah and Idaho" description="Compare Bear Lake communities such as Garden City, Laketown, Fish Haven, and St. Charles with local real estate guidance from Jason Petersen." canonical="/bear-lake-communities/" schema={communitySchema}>
  <section class="py-16 sm:py-24">
    <div class="container-narrow">
      <p class="eyebrow">Bear Lake Communities</p>
      <h1 class="mt-4 font-serif text-5xl font-semibold tracking-tight">Compare Bear Lake Real Estate Areas Before You Search</h1>
      <p class="mt-6 text-lg leading-8 text-lake-900/75">Bear Lake spans Utah and Idaho, and the right fit can depend on more than the listing photos. Jason helps buyers and sellers compare community feel, access, rental rules, building considerations, lake proximity, and current market context before making a property decision.</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="btn-primary" href={withBasePath('/contact/')}>Ask Jason about an area</a>
        <a class="btn-secondary" href={withBasePath('/buying-and-selling/')}>Review buyer and seller guidance</a>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-wide">
      <SectionHeader eyebrow="Local Area Guide" title="Utah and Idaho Bear Lake Communities" text="Use this as a starting point, then confirm property-specific details with current local data, HOA documents, local authorities, and appropriate professionals." />
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {towns.map((town) => <article class="card"><p class="eyebrow">{town.term}</p><h2 class="mt-2 font-serif text-2xl font-semibold">{town.name}</h2><p class="mt-3 leading-7 text-lake-900/70">{town.description}</p></article>)}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-wide grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">How to Compare Areas</p>
        <h2 class="mt-3 font-serif text-3xl font-semibold">A Practical Checklist for Bear Lake Property Decisions</h2>
        <p class="mt-5 leading-8 text-lake-900/75">A national search portal can show bedrooms, bathrooms, price, and photos. A local conversation can add the details that often affect ownership experience: access, utilities, local rules, neighborhood norms, building feasibility, and how similar properties are positioned in the current market.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {comparisonPoints.map((point) => <div class="card"><h3 class="font-serif text-xl font-semibold">{point}</h3></div>)}
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-narrow rounded-[2rem] bg-timber-50 p-8 shadow-soft">
      <h2 class="font-serif text-3xl font-semibold">Why This Page Exists Before Live Listings</h2>
      <p class="mt-5 leading-8 text-lake-900/75">Because the website is early, it is better to publish one useful, accurate community guide than several thin town pages or automated listing pages. As the site grows, this page can become the hub for deeper community resources, market notes, listing search pages, and buyer/seller FAQs.</p>
      <p class="mt-5 leading-8 text-lake-900/75">For current inventory and property-specific guidance, contact Jason directly. He can help connect your goals with current availability and local due-diligence questions.</p>
    </div>
  </section>

  <CTASection />
</BaseLayout>
