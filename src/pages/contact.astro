---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContactForm from '@/components/forms/ContactForm.astro';
import { site } from '@/data/site';
---
<BaseLayout title="Contact Jason Petersen" description="Call, text, or message Jason Petersen for Bear Lake real estate guidance throughout Rich County, Bear Lake County, and the Utah and Idaho sides of Bear Lake.">
  <section class="py-16 sm:py-24"><div class="container-wide grid gap-10 lg:grid-cols-[0.85fr_1.15fr]"><div><p class="eyebrow">Contact Jason</p><h1 class="mt-4 font-serif text-5xl font-semibold tracking-tight">Call, text, or send a short Bear Lake property question</h1><p class="mt-6 text-lg leading-8 text-lake-900/75">For current Bear Lake property options, seller valuation questions, second homes, cabins, condos, townhomes, lots, land, or nightly-rental-aware guidance, reach out directly. Jason promptly returns calls, texts, and inquiries throughout Garden City, Laketown, Fish Haven, St. Charles, Bear Lake West, Harbor Village, Sweetwater, Pickleville, Paris, Bloomington, Dingle, Rich County, Bear Lake County, and both sides of Bear Lake.</p><div class="mt-8 rounded-[2rem] bg-lake-900 p-6 text-white"><p class="text-sm uppercase tracking-[0.18em] text-lake-100/70">Call/Text</p><a class="mt-2 block font-serif text-4xl font-semibold" href={site.phoneHref}>{site.phone}</a><p class="mt-4 text-lake-100/75">Jason Petersen · {site.title}<br />{site.brokerage} · {site.licensed}</p><a class="mt-4 inline-block text-lake-100 underline decoration-lake-100/50 underline-offset-4" href={site.emailHref}>{site.emailTarget}</a></div></div><div><h2 class="font-serif text-3xl font-semibold">General inquiry</h2><p class="mt-3 leading-7 text-lake-900/70">Keep it simple. Share what you are looking for, where you are looking, and your timing. Jason can follow up with practical next steps.</p><div class="mt-6"><ContactForm /></div></div></div></section>
  <section class="bg-white py-16"><div class="container-narrow"><h2 class="font-serif text-3xl font-semibold">Seller valuation request</h2><p class="mt-3 leading-7 text-lake-900/70">Thinking about selling? Send the property address and a few notes about timing, condition, updates, and questions.</p><div class="mt-6"><ContactForm type="seller" /></div></div></section>
</BaseLayout>
