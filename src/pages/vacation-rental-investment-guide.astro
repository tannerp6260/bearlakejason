---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/sections/CTASection.astro';
import { rentalDisclaimer } from '@/data/site';
import { withBasePath } from '@/utils/paths';
const topics = ['Cost and carrying costs', 'Rental potential by property', 'Bedroom count and sleeping layout', 'Seasonal rental windows', 'Parking and access', 'HOA and local restrictions', 'Amenities and guest usability', 'Property management considerations'];
---
<BaseLayout title="Bear Lake Rental and Investment-Minded Guidance" description="Bear Lake real estate guidance for nightly rental, short-term rental, and investment-minded property questions with careful, property-specific local context.">
  <section class="py-16 sm:py-24"><div class="container-narrow"><p class="eyebrow">Rental-aware guidance</p><h1 class="mt-4 font-serif text-5xl font-semibold tracking-tight">Bear Lake nightly rental and investment-minded property considerations</h1><p class="mt-6 text-lg leading-8 text-lake-900/75">Jason helps investment-minded buyers and sellers talk through Bear Lake nightly rental and short-term rental considerations clearly, carefully, and with property-specific local context.</p><a class="btn-primary mt-8" href={withBasePath('/contact/')}>Ask Jason about rental-aware properties</a></div></section>
  <section class="bg-white py-16"><div class="container-wide grid gap-10 lg:grid-cols-[0.9fr_1.1fr]"><div><h2 class="font-serif text-3xl font-semibold">Practical rental considerations</h2><p class="mt-5 leading-8 text-lake-900/75">Jason helps clients think through Bear Lake rental potential, HOA and local rules, property features, location, bedroom count, parking, amenities, and competition in the area. Bear Lake View Realty also brings local familiarity with vacation-rental and second-home considerations.</p><p class="mt-5 leading-8 text-lake-900/75">Jason can help you understand property-specific questions before you buy or position a property for sale, including local rules, buyer due diligence, property details, and conversations to have with qualified tax, lending, insurance, or property-management professionals.</p></div><div class="grid gap-4 sm:grid-cols-2">{topics.map((topic) => <div class="card"><h3 class="font-serif text-xl font-semibold">{topic}</h3></div>)}</div></div></section>
  <section class="py-16"><div class="container-narrow rounded-[2rem] border border-lake-900/10 bg-lake-50 p-8"><h2 class="font-serif text-3xl font-semibold">Important rental note</h2><p class="mt-4 text-lg leading-8 text-lake-900/75">{rentalDisclaimer}</p></div></section>
  <CTASection />
</BaseLayout>
