---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/sections/CTASection.astro';
import { rentalDisclaimer } from '@/data/site';
import { withBasePath } from '@/utils/paths';
const topics = ['Cost and carrying costs', 'Rentable vs non-rentable areas', 'How many people the property can sleep', 'Seasonal rental windows', 'Parking and access', 'HOA and local restrictions', 'Layout and guest usability', 'Property management considerations'];
---
<BaseLayout title="Bear Lake Vacation Rental & Investment Guidance" description="Vacation-rental-aware Bear Lake real estate guidance for investment-minded buyers without guaranteed rental income or return claims.">
  <section class="py-16 sm:py-24"><div class="container-narrow"><p class="eyebrow">Rental-aware guidance</p><h1 class="mt-4 font-serif text-5xl font-semibold tracking-tight">Bear Lake vacation rental and investment property considerations</h1><p class="mt-6 text-lg leading-8 text-lake-900/75">Jason helps investment-minded buyers and sellers talk through Bear Lake vacation rental property considerations clearly, carefully, and without guaranteed return claims.</p><a class="btn-primary mt-8" href={withBasePath('/contact/')}>Ask Jason about vacation-rental-friendly properties</a></div></section>
  <section class="bg-white py-16"><div class="container-wide grid gap-10 lg:grid-cols-[0.9fr_1.1fr]"><div><h2 class="font-serif text-3xl font-semibold">Experience with rental considerations</h2><p class="mt-5 leading-8 text-lake-900/75">Jason has experience helping clients think through Bear Lake vacation rental considerations. Bear Lake View Realty also has familiarity with vacation rentals, and Jason’s broker previously owned a rental company.</p><p class="mt-5 leading-8 text-lake-900/75">The goal is not to promise income. The goal is to help you understand property-specific questions before you buy or position a property for sale.</p></div><div class="grid gap-4 sm:grid-cols-2">{topics.map((topic) => <div class="card"><h3 class="font-serif text-xl font-semibold">{topic}</h3></div>)}</div></div></section>
  <section class="py-16"><div class="container-narrow rounded-[2rem] border border-lake-900/10 bg-lake-50 p-8"><h2 class="font-serif text-3xl font-semibold">Important rental disclaimer</h2><p class="mt-4 text-lg leading-8 text-lake-900/75">{rentalDisclaimer}</p></div></section>
  <CTASection />
</BaseLayout>
