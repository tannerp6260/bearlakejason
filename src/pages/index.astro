---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CallButton from '@/components/common/CallButton.astro';
import SectionHeader from '@/components/common/SectionHeader.astro';
import CTASection from '@/components/sections/CTASection.astro';
import { services } from '@/data/services';
import { towns } from '@/data/towns';
import { site } from '@/data/site';
import { homeFaqs } from '@/data/faqs';
import { withBasePath } from '@/utils/paths';
const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${site.domain}/#webpage`,
    url: site.domain,
    name: 'Bear Lake Real Estate with Local Expertise',
    description:
      'Jason Petersen with Bear Lake View Realty helps buyers and sellers around Bear Lake, including Garden City, Fish Haven, Laketown, and St. Charles.',
    isPartOf: { '@id': `${site.domain}/#website` },
    about: { '@id': `${site.domain}/#real-estate-agent` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: homeFaqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  },
];
---
<BaseLayout title="Bear Lake Real Estate with Local Expertise" description="Jason Petersen with Bear Lake View Realty helps buyers and sellers around Bear Lake, including Garden City, Fish Haven, Laketown, and St. Charles." schema={homeSchema}>
  <section class="relative isolate min-h-[calc(100svh-5rem)] overflow-hidden bg-lake-950">
    <img
      class="absolute inset-0 z-0 h-full w-full object-cover object-center"
      src={withBasePath('/images/scenery/bearlake_sunset2.jpeg')}
      alt="Bear Lake sunset over the water and mountains"
      onerror={`this.onerror=null;this.src='${withBasePath('/images/scenery/bearlake_sunset.jpeg')}'`}
    />
    <div class="absolute inset-0 z-10 bg-lake-950/20" aria-hidden="true"></div>
    <div class="absolute inset-0 z-10 bg-gradient-to-r from-black/80 via-black/45 to-transparent" aria-hidden="true"></div>
    <div class="container-wide relative z-20 flex min-h-[calc(100svh-5rem)] items-center py-16 sm:py-24">
      <div class="max-w-3xl rounded-[2rem] border border-white/85 bg-white/90 p-8 shadow-soft backdrop-blur-sm sm:p-10 lg:p-12">
        <p class="eyebrow">Bear Lake Real Estate · Utah &amp; Idaho</p>
        <h1 class="mt-4 font-serif text-5xl font-semibold tracking-tight text-lake-950 sm:text-6xl lg:text-7xl">Bear Lake Real Estate with Local Expertise</h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-lake-900/75">Jason Petersen, REALTOR® / Associate Broker with Bear Lake View Realty, helps buyers and sellers navigate Bear Lake homes, cabins, second homes, condos, townhomes, building lots, and investment-minded property questions with local context and responsive communication.</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row"><CallButton /><a class="btn-secondary" href={withBasePath('/contact/')}>Ask About Bear Lake Property</a></div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-wide grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {['25+ Years Living in the Area', 'Licensed Utah + Idaho Guidance', 'Fast Communication and Follow-Through', 'Builder and Local Referral Network'].map((item) => <div class="card"><p class="font-serif text-xl font-semibold text-lake-950">{item}</p></div>)}
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container-wide">
      <SectionHeader eyebrow="How Jason Helps" title="Practical Help for Bear Lake Buyers and Sellers" text="Personalized, practical guidance focused on the questions people actually have before they make a Bear Lake real estate decision." />
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">{services.map((service) => <article class="card"><h3 class="font-serif text-2xl font-semibold">{service.title}</h3><p class="mt-3 leading-7 text-lake-900/70">{service.description}</p></article>)}</div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-wide">
      <SectionHeader eyebrow="Local Expertise" title="Bear Lake Communities in Utah and Idaho" text="Bear Lake is not one-size-fits-all. Jason helps compare local differences across Rich County, Bear Lake County, and the Utah and Idaho Bear Lake communities." />
      <div class="mt-10 grid gap-5 md:grid-cols-2">{towns.map((town) => <article class="card"><p class="eyebrow">{town.term}</p><h3 class="mt-2 font-serif text-2xl font-semibold">{town.name}</h3><p class="mt-3 leading-7 text-lake-900/70">{town.description}</p></article>)}</div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-narrow rounded-[2rem] bg-timber-50 p-8 text-center shadow-soft">
      <p class="eyebrow">Current Listings</p>
      <h2 class="mt-3 font-serif text-3xl font-semibold">For Current Bear Lake Listings, Contact Jason Directly</h2>
      <p class="mx-auto mt-4 max-w-2xl leading-7 text-lake-900/70">For current Bear Lake listings, local opportunities, and property-specific guidance, contact Jason directly. He can help you understand availability, pricing context, and property-specific details.</p>
      <div class="mt-7"><CallButton label={`Jason Petersen: ${site.phone}`} /></div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-wide">
      <SectionHeader eyebrow="What to Expect" title="A Simple Process for Bear Lake Property Decisions" text="Expect direct contact, local context, and clear next steps without pressure or exaggerated claims." />
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        <article class="card"><h3 class="font-serif text-2xl font-semibold">Start with Goals</h3><p class="mt-3 leading-7 text-lake-900/70">Share whether you are buying, selling, building, comparing towns, or evaluating short-term rental considerations.</p></article>
        <article class="card"><h3 class="font-serif text-2xl font-semibold">Review Local Tradeoffs</h3><p class="mt-3 leading-7 text-lake-900/70">Talk through access, utilities, HOA rules, lake proximity, seasonality, Utah versus Idaho differences, and current market context.</p></article>
        <article class="card"><h3 class="font-serif text-2xl font-semibold">Move with a Plan</h3><p class="mt-3 leading-7 text-lake-900/70">Decide on next steps for showings, pricing, a seller valuation, builder conversations, or property-specific due diligence.</p></article>
      </div>
    </div>
  </section>

  <section class="bg-white py-16">
    <div class="container-wide grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">Bear Lake Search Guide</p>
        <h2 class="mt-3 font-serif text-3xl font-semibold">Helpful Starting Points While the Site Is Still Growing</h2>
        <p class="mt-5 leading-8 text-lake-900/75">This website is intentionally focused on useful local guidance before adding live MLS listings or a blog. If you are researching Bear Lake real estate, start with local tradeoffs first: Utah versus Idaho location, year-round access, HOA rules, utilities, rental rules, lake proximity, and whether a cabin, condo, building lot, or full-time home fits your goals.</p>
        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <a class="btn-primary" href={withBasePath('/bear-lake-communities/')}>Compare Bear Lake communities</a>
          <a class="btn-secondary" href={withBasePath('/buying-and-selling/')}>Buyer and seller guide</a>
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <article class="card"><h3 class="font-serif text-xl font-semibold">For Buyers</h3><p class="mt-3 leading-7 text-lake-900/70">Ask about current listings, off-market context, showing logistics, lot due diligence, and neighborhood differences that may not be obvious from a national portal.</p></article>
        <article class="card"><h3 class="font-serif text-xl font-semibold">For Sellers</h3><p class="mt-3 leading-7 text-lake-900/70">Discuss pricing, buyer demand, property prep, seasonal timing, and how to position cabins, land, condos, and homes around Bear Lake.</p></article>
        <article class="card"><h3 class="font-serif text-xl font-semibold">For Lot Buyers</h3><p class="mt-3 leading-7 text-lake-900/70">Review access, utilities, slope, septic, water, builder fit, HOA details, and local approval questions before committing to land.</p></article>
        <article class="card"><h3 class="font-serif text-xl font-semibold">For Rental-Aware Buyers</h3><p class="mt-3 leading-7 text-lake-900/70">Treat rental potential as property-specific due diligence, not a guarantee. Confirm rules, expenses, management, insurance, taxes, and guest usability.</p></article>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-narrow">
      <SectionHeader eyebrow="Frequently Asked Questions" title="Bear Lake Real Estate Questions" text="Clear answers for common early-stage buyer and seller questions." />
      <div class="mt-10 grid gap-5">
        {homeFaqs.map((faq) => <article class="card"><h3 class="font-serif text-2xl font-semibold">{faq.question}</h3><p class="mt-3 leading-7 text-lake-900/70">{faq.answer}</p></article>)}
      </div>
    </div>
  </section>
  <CTASection />
</BaseLayout>
