---
import CallButton from '@/components/common/CallButton.astro';
import { withBasePath } from '@/utils/paths';
---
<section class="bg-lake-900 py-16 text-white">
  <div class="container-narrow text-center">
    <p class="eyebrow text-timber-100">Ready When You Are</p>
    <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight sm:text-4xl">Have a Bear Lake Property Question?</h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-timber-100">Call or text Jason for practical local guidance before you buy, sell, build, or evaluate vacation-rental considerations.</p>
    <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
      <CallButton label="Call/Text Jason" />
      <a class="btn-secondary" href={withBasePath('/contact/')}>Ask About Bear Lake Property</a>
    </div>
  </div>
</section>
