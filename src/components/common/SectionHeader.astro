---
const { eyebrow, title, text, align = 'left' } = Astro.props;
const alignment = align === 'center' ? 'mx-auto text-center' : '';
---
<div class={`max-w-3xl ${alignment}`}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-lake-950 sm:text-4xl">{title}</h2>
  {text && <p class="mt-4 text-lg leading-8 text-lake-900/75">{text}</p>}
</div>
