---
import { navigation } from '@/data/navigation';
import { site } from '@/data/site';
import { withBasePath } from '@/utils/paths';
---
<footer class="border-t border-lake-900/10 bg-lake-950 text-white">
  <div class="container-wide grid gap-10 py-12 md:grid-cols-[1.4fr_0.9fr_1fr]">
    <div>
      <p class="font-serif text-2xl font-semibold">Jason Petersen</p>
      <p class="mt-2 text-lake-100/80">{site.title} with {site.brokerage}. {site.licensed}.</p>
      <p class="mt-4 max-w-xl text-sm leading-6 text-lake-100/70">Local Bear Lake real estate guidance for buyers, sellers, cabins, building lots, second homes, condos, townhomes, and rental-aware property conversations across Rich County, Bear Lake County, and Utah and Idaho Bear Lake communities.</p>
    </div>
    <div>
      <p class="font-semibold">Explore</p>
      <div class="mt-4 grid gap-2">
        {navigation.map((item) => <a class="text-sm text-lake-100/75 hover:text-white" href={withBasePath(item.href)}>{item.label}</a>)}
      </div>
    </div>
    <div>
      <p class="font-semibold">Brokerage</p>
      <div class="mt-4 flex w-56 items-center justify-center rounded-2xl bg-white p-3">
        <img class="max-h-24 max-w-full object-contain object-center" src={withBasePath(site.brokerageLogo)} alt={`${site.brokerage} logo`} loading="lazy" />
      </div>
      <p class="mt-4 text-sm leading-6 text-lake-100/75">{site.brokerage}<br />{site.brokerageAddress}<br /><a class="hover:text-white" href={site.brokeragePhoneHref}>Brokerage: {site.brokeragePhone}</a></p>
      <p class="mt-4 font-semibold">Contact</p>
      <a class="mt-3 block text-sm text-lake-100/75 hover:text-white" href={site.phoneHref}>Jason: {site.phone}</a>
      <a class="mt-2 block text-sm text-lake-100/75 hover:text-white" href={site.emailHref}>{site.emailTarget}</a>
      <p class="mt-4 text-xs leading-5 text-lake-100/55">Equal Housing Opportunity. Information should be independently verified with appropriate professionals, local authorities, HOA documents, and current market data.</p>
    </div>
  </div>
  <div class="border-t border-white/10 py-5">
    <div class="container-wide text-xs text-lake-100/60">© {new Date().getFullYear()} Jason Petersen · {site.brokerage}. Information is for general guidance and is not a promise of sale price, rental income, occupancy, resale value, or investment performance.</div>
  </div>
  <div class="fixed inset-x-3 bottom-3 z-50 grid grid-cols-3 gap-2 rounded-3xl border border-lake-900/10 bg-white/95 p-2 shadow-soft backdrop-blur sm:hidden" aria-label="Quick contact options">
    <a class="rounded-2xl bg-lake-800 px-3 py-3 text-center text-xs font-bold text-white" href={site.phoneHref}>Call Jason</a>
    <a class="rounded-2xl border border-lake-700/20 bg-timber-50 px-3 py-3 text-center text-xs font-bold text-lake-900" href={site.smsHref}>Text Jason</a>
    <a class="rounded-2xl border border-lake-700/20 bg-timber-50 px-3 py-3 text-center text-xs font-bold text-lake-900" href={withBasePath('/contact/')}>Ask a Question</a>
  </div>
</footer>
