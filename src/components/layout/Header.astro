---
import { navigation } from '@/data/navigation';
import { site } from '@/data/site';
import { withBasePath } from '@/utils/paths';
---
<header class="sticky top-0 z-50 border-b border-lake-900/10 bg-timber-50/90 backdrop-blur">
  <nav class="container-wide flex min-h-20 items-center justify-between gap-4" aria-label="Primary navigation">
    <a href={withBasePath('/')} class="group flex items-center gap-3" aria-label="Jason Petersen home">
      <img
        class="h-12 shrink-0 rounded-2xl border border-white/80 shadow-sm"
        src={withBasePath('/images/headshots/jp_headshot.png')}
        alt="Jason Petersen"
      />
      <span class="leading-tight">
        <span class="block font-serif text-lg font-semibold text-lake-950">Jason Petersen</span>
        <span class="block text-xs font-semibold uppercase tracking-wide text-lake-800">Bear Lake View Realty</span>
      </span>
    </a>
    <div class="hidden items-center gap-7 lg:flex">
      {navigation.map((item) => (
        <a class="text-sm font-semibold text-lake-900/75 transition hover:text-lake-950" href={withBasePath(item.href)}>{item.label}</a>
      ))}
    </div>
    <a class="hidden rounded-full bg-lake-800 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-lake-900 sm:inline-flex" href={site.phoneHref}>
      {site.phone}
    </a>
  </nav>
  <div class="container-wide flex gap-2 overflow-x-auto pb-3 lg:hidden" aria-label="Mobile navigation">
    {navigation.map((item) => (
      <a class="shrink-0 rounded-full border border-lake-900/10 bg-white px-4 py-2 text-sm font-semibold text-lake-900" href={withBasePath(item.href)}>{item.label}</a>
    ))}
  </div>
</header>
