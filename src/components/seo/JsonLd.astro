---
import { site } from '@/data/site';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: site.name,
  jobTitle: site.title,
  worksFor: {
    '@type': 'RealEstateAgent',
    name: site.brokerage,
    address: {
      '@type': 'PostalAddress',
      streetAddress: '65 West Logan Road #9B',
      addressLocality: 'Garden City',
      addressRegion: 'UT',
      postalCode: '84028',
      addressCountry: 'US',
    },
    telephone: site.brokeragePhone,
  },
  telephone: site.phone,
  url: site.domain,
  areaServed: ['Bear Lake', 'Rich County UT', 'Bear Lake County ID', 'Garden City UT', 'Fish Haven ID', 'Laketown UT', 'St. Charles ID'],
  knowsAbout: [
    'Bear Lake real estate',
    'Bear Lake cabins',
    'Bear Lake building lots',
    'Bear Lake second homes',
    'Bear Lake nightly rental property considerations',
    'Utah and Idaho Bear Lake property guidance',
  ],
};
---
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
