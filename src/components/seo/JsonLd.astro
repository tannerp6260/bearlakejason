---
import { site } from '@/data/site';
const schema = {
  '@context': 'https://schema.org',
  '@type': 'RealEstateAgent',
  name: site.name,
  jobTitle: site.title,
  worksFor: {
    '@type': 'RealEstateAgent',
    name: site.brokerage,
    address: site.address,
  },
  telephone: site.phone,
  email: site.emailTarget,
  url: site.domain,
  areaServed: [
    'Bear Lake',
    'Bear Lake Utah',
    'Bear Lake Idaho',
    'Rich County UT',
    'Bear Lake County ID',
    'Garden City UT',
    'Laketown UT',
    'Fish Haven ID',
    'St. Charles ID',
    'Bear Lake West ID',
    'Harbor Village UT',
    'Sweetwater UT',
    'Pickleville UT',
    'Paris ID',
    'Bloomington ID',
    'Dingle ID',
  ],
  knowsAbout: [
    'Bear Lake real estate',
    'Bear Lake cabins',
    'Bear Lake condos and townhomes',
    'Bear Lake building lots',
    'Bear Lake land',
    'Bear Lake second homes',
    'Bear Lake nightly rental property considerations',
  ],
};
---
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
