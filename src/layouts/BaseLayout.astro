---
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { site } from '@/data/site';
import { withBasePath } from '@/utils/paths';
import '@/styles/global.css';

const {
  title,
  description = site.description,
  image = site.socialImage,
  canonical = Astro.url.pathname,
} = Astro.props;
const pageTitle = title ? `${title} | Jason Petersen Bear Lake Real Estate` : 'Jason Petersen Bear Lake Real Estate';
const canonicalUrl = new URL(canonical, site.domain).toString();
const imageUrl = new URL(withBasePath(image), site.domain).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0f3d4a" />
    <link rel="icon" type="image/svg+xml" href={withBasePath(site.logoImage)} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <JsonLd />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
